---
const skills = [
  { group: 'Cloud', items: 'AWS · GCP · DigitalOcean' },
  { group: 'IaC', items: 'Terraform · Ansible · Bash' },
  { group: 'Observability', items: 'Prometheus · Grafana · Loki · Alertmanager' },
  { group: 'CI/CD', items: 'GitHub Actions · GitLab CI · GitOps' },
  { group: 'Containers', items: 'Docker · Docker Compose · Nginx' },
  { group: 'Web / Full-stack', items: 'React · Node.js · TypeScript · Python · PostgreSQL · MongoDB' },
] as const;
---

<section id="about" class="border-t border-line px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-12 lg:grid-cols-[1fr_auto] lg:gap-20">

      <div>
        <p class="font-mono text-xs font-medium uppercase tracking-[0.18em] text-accent">About</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink sm:text-4xl">
          Senior judgment, startup speed
        </h2>

        <div class="mt-6 max-w-2xl space-y-4 text-muted leading-relaxed">
          <p>
            I'm a platform/DevOps engineer specializing in cloud infrastructure — greenfield builds,
            cloud migrations, and Infrastructure as Code. I help startups and small teams stand up
            reliable, automated, production-ready systems (Terraform, Ansible, CI/CD, observability)
            on a project basis, so they get senior platform engineering without the cost or lead time
            of a full-time hire.
          </p>
          <p>
            Five years building production systems across AWS, GCP, and DigitalOcean, with a full
            MERN-stack background that means I understand the application layer, not just the
            infrastructure beneath it. I lean on AI coding agents as horsepower under that
            judgment — which means startup-grade speed without giving up the operational rigor
            production demands.
          </p>
        </div>
      </div>

      <!-- Skills -->
      <div class="lg:min-w-72">
        <p class="font-mono text-xs font-medium uppercase tracking-[0.18em] text-accent">Stack</p>
        <dl class="mt-4 space-y-3">
          {skills.map(({ group, items }) => (
            <div class="flex flex-col gap-0.5">
              <dt class="font-mono text-[10px] uppercase tracking-widest text-muted">{group}</dt>
              <dd class="text-sm text-ink">{items}</dd>
            </div>
          ))}
        </dl>
      </div>

    </div>
  </div>
</section>
