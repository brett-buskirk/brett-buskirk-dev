---
import { SITE } from '../lib/site';
---

<section id="contact" class="border-t border-line px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-2xl text-center">

      <p class="font-mono text-xs font-medium uppercase tracking-[0.18em] text-accent">Contact</p>

      <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink sm:text-4xl lg:text-5xl">
        Let's build something.
      </h2>

      <p class="mt-5 text-lg leading-relaxed text-muted">
        Ready to stand up real infrastructure? Send me what you're working on
        and we'll figure out the right scope together.
      </p>

      <div class="mt-10 flex flex-col items-center gap-4">
        <a
          href={`mailto:${SITE.email}`}
          class="inline-flex items-center gap-2 rounded-md bg-accent px-8 py-3.5 text-base font-semibold text-bg hover:bg-accent-2 transition-colors duration-150"
        >
          Start a project
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
          </svg>
        </a>
        <a
          href={`mailto:${SITE.email}`}
          class="font-mono text-sm text-muted hover:text-ink transition-colors"
        >
          {SITE.email}
        </a>
      </div>

    </div>
  </div>
</section>
